{
  "name": "go2rtc-tauri-app",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env RUST_BACKTRACE=1 concurrently -k \"tauri dev\"",
    "lint": "eslint . --fix",
    "build": "tauri build",
    "vite:dev": "vite dev",
    "vite:build": "vite build",
    "devtools": "pnpm vue-devtools",
    "ts-check": "vue-tsc --noEmit",
    "preview": "vite preview",
    "check": "cd src-tauri && cargo check",
    "up": "taze major -I",
    "check-sidebar": "node scripts/check-sidebar.mjs",
    "postinstall": "npx simple-git-hooks"
  },
  "dependencies": {
    "@arco-design/web-vue": "^2.55.1",
    "@tauri-apps/api": "^1.5.3",
    "@vueuse/core": "^10.9.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "lodash-es": "^4.17.21",
    "nanoid": "^5.0.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^2.13.3",
    "@iconify-json/carbon": "^1.1.31",
    "@tauri-apps/cli": "^1.5.11",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.12.7",
    "@unocss/eslint-plugin": "^0.59.2",
    "@unocss/reset": "^0.59.2",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/devtools": "^7.0.27",
    "adm-zip": "^0.5.12",
    "axios": "^1.6.8",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-plugin-format": "^0.1.0",
    "fs-extra": "^11.2.0",
    "https-proxy-agent": "^7.0.4",
    "less": "^4.2.0",
    "lint-staged": "^15.2.2",
    "shiki": "^1.3.0",
    "simple-git-hooks": "^2.11.1",
    "taze": "^0.13.4",
    "typescript": "^5.4.5",
    "unocss": "^0.59.2",
    "unplugin-auto-expose": "0.3.0",
    "unplugin-auto-import": "^0.17.5",
    "unplugin-vue-components": "^0.26.0",
    "unplugin-vue-router": "^0.8.6",
    "vite": "^5.2.8",
    "vue-tsc": "^2.0.13"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint . --fix"
  }
}
